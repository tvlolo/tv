    <script>
        // 滚动时添加模糊效果
        window.addEventListener('scroll', function() {
            if (window.scrollY > 50) {
                document.body.classList.add('scrolled');
            } else {
                document.body.classList.remove('scrolled');
            }
        });

        // 音乐播放功能
        document.addEventListener('DOMContentLoaded', function() {
            const musicToggle = document.getElementById('musicToggle');
            const musicIcon = musicToggle.querySelector('i');
            const bgMusic = document.getElementById('bgMusic');
            
            // 尝试自动播放音乐
            function tryAutoPlay() {
                bgMusic.play().then(() => {
                    console.log('音乐自动播放成功');
                    musicIcon.classList.replace('fa-music', 'fa-volume-up');
                    localStorage.setItem('music', 'on');
                }).catch(e => {
                    console.log('自动播放被阻止:', e);
                    // 如果自动播放失败，则等待用户交互
                    document.addEventListener('click', function firstInteraction() {
                        bgMusic.play();
                        musicIcon.classList.replace('fa-music', 'fa-volume-up');
                        localStorage.setItem('music', 'on');
                        document.removeEventListener('click', firstInteraction);
                    }, { once: true });
                });
            }
            
            // 检查本地存储的音乐设置
            const savedMusic = localStorage.getItem('music');
            if (savedMusic !== 'off') {
                tryAutoPlay();
            } else {
                musicIcon.classList.replace('fa-volume-up', 'fa-music');
            }
            
            // 切换音乐
            musicToggle.addEventListener('click', function() {
                if (bgMusic.paused) {
                    bgMusic.play();
                    musicIcon.classList.replace('fa-music', 'fa-volume-up');
                    localStorage.setItem('music', 'on');
                } else {
                    bgMusic.pause();
                    musicIcon.classList.replace('fa-volume-up', 'fa-music');
                    localStorage.setItem('music', 'off');
                }
            });
            
            // 复制跑马灯内容以实现无缝循环
            const marquee = document.querySelector('.marquee');
            const marqueeContent = document.querySelector('.marquee-content');
            const clone = marqueeContent.cloneNode(true);
            marquee.appendChild(clone);
            
            // 初始化所有卡片状态
            initializeBookmarks();
        });
        
        // 卡片折叠功能
        function toggleBookmark(headerElement) {
            const bookmark = headerElement.closest('.bookmark');
            const links = bookmark.querySelector('.bookmark-links');
            
            // 切换折叠状态
            headerElement.classList.toggle('collapsed');
            links.classList.toggle('collapsed');
            
            // 保存状态到本地存储
            const bookmarkId = Array.from(bookmark.parentElement.children).indexOf(bookmark);
            const isCollapsed = headerElement.classList.contains('collapsed');
            saveBookmarkState(bookmarkId, isCollapsed);
        }
        

// 初始化书签状态 - 默认折叠，但如果用户之前有设置则使用用户设置
function initializeBookmarks() {
    const bookmarks = document.querySelectorAll('.bookmark');
    
    bookmarks.forEach((bookmark, index) => {
        // 从本地存储获取状态，如果没有设置过则默认折叠
        const isCollapsed = localStorage.getItem(`bookmark_${index}`) === 'true' || 
                           localStorage.getItem(`bookmark_${index}`) === null; // 如果没设置过，也默认为折叠
        
        const header = bookmark.querySelector('.bookmark-header');
        const links = bookmark.querySelector('.bookmark-links');
        
        if (isCollapsed) {
            header.classList.add('collapsed');
            links.classList.add('collapsed');
        }
        
        // 如果是第一次访问（没有本地存储记录），则保存默认折叠状态
        if (localStorage.getItem(`bookmark_${index}`) === null) {
            localStorage.setItem(`bookmark_${index}`, 'true');
        }
    });
}
        
        // 保存书签状态到本地存储
        function saveBookmarkState(index, isCollapsed) {
            localStorage.setItem(`bookmark_${index}`, isCollapsed);
        }
    </script>
</body>
</html>
